# Google Sheets Webhook URL (From Google Apps Script Deployment)
WEBHOOK_URL=https://script.google.com/macros/s/.../exec

# LinkedIn Session Cookie (Optional, helps avoid blocks)
# To get this: Open LinkedIn -> Inspect -> Application -> Cookies -> li_at
LINKEDIN_LI_AT=

# Search Settings
LOCATION="New York, NY"
EXPERIENCE_LEVEL="0-2 years" # "Entry Level"
